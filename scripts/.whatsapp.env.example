# Copia este archivo a scripts/.whatsapp.env y completa tus datos
# URL que usará scripts/enviar_recordatorios_whatsapp.php
WHATSAPP_REMINDER_WEBHOOK_URL=http://127.0.0.1:8090/whatsapp_webhook_receiver.php

# Modo seguro: 1 = no envía WhatsApp y no marca alarmas como avisadas
WHATSAPP_REMINDER_SAFE_MODE=0

# Horas entre avisos del mismo resultado (6 recomendado en producción)
WHATSAPP_REMINDER_THROTTLE_HOURS=6

# Credenciales Meta WhatsApp Cloud API (para envío real)
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_TOKEN=

# Modo de envío: text (mensaje libre) o template (plantilla aprobada)
META_WHATSAPP_SEND_MODE=text

# Si usas template, define nombre y lenguaje (ej. hello_world / en_US)
META_WHATSAPP_TEMPLATE_NAME=hello_world
META_WHATSAPP_TEMPLATE_LANG=en_US

# En 1, envía parámetros al body de la plantilla (solo si tu plantilla los espera)
META_WHATSAPP_TEMPLATE_USE_PARAMS=0

# Fallback automático si la plantilla principal no existe/no está aprobada
META_WHATSAPP_TEMPLATE_FALLBACK_NAME=hello_world
META_WHATSAPP_TEMPLATE_FALLBACK_LANG=en_US

# Prefijo país para números locales (Perú=51)
META_WHATSAPP_COUNTRY_CODE=51
