RewriteEngine On

# Favicon por empresa (multi-dominio)
RewriteRule ^favicon\.ico$ src/favicon.php [L]

# Evitar listado de directorios
Options -Indexes

# Redirección 301 a HTTPS (compatible con proxy/CDN), excepto localhost
RewriteCond %{HTTP_HOST} !^localhost$ [NC]
RewriteCond %{HTTP_HOST} !^127\.0\.0\.1$ [NC]
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP:X-Forwarded-Proto} =http
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Bloquear acceso público a vendor (opcional pero recomendado)
RedirectMatch 404 ^/vendor/.*$

# Bloquear carpetas que no deben ser públicas (no afecta includes PHP)
RedirectMatch 404 ^/(tmp|sql|scripts|docs|clients)/.*$

# Bloquear acceso directo a configuraciones sensibles dentro de /src
RedirectMatch 404 ^/src/(config|conexion)/.*$

# Bloquear archivos sensibles en la raíz
RedirectMatch 404 ^/(composer\.(json|lock)|\.env(\..*)?|\.git(ignore|attributes)?|README\.md|.*\.sql)$

# Cabeceras de seguridad
<IfModule mod_headers.c>
	Header always set Strict-Transport-Security "max-age=31536000"
	Header always set Content-Security-Policy "upgrade-insecure-requests"
	Header always set X-Content-Type-Options "nosniff"
	Header always set X-Frame-Options "SAMEORIGIN"
	Header always set Referrer-Policy "no-referrer-when-downgrade"
</IfModule>
